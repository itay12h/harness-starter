{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Read",
        "hooks": [
          { "type": "command", "command": "$(command -v python3 || command -v python) \"$CLAUDE_PROJECT_DIR/.claude/hooks/security_guard.py\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "$(command -v python3 || command -v python) \"$CLAUDE_PROJECT_DIR/.claude/hooks/post_tool_use_lint.py\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "$(command -v python3 || command -v python) \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop_validate.py\"" }
        ]
      }
    ]
  }
}
